rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SECOURS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getProfile().role == 'admin';
    }

    // --- PROFILS UTILISATEURS ---
    match /userProfiles/{userId} {
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
    }

    // --- DONNÉES DU CLUB ---
    match /users/{userId}/{document=**} {
       // L'Admin propriétaire a tous les droits
       allow read, write: if isSignedIn() && request.auth.uid == userId;

       // Le Staff (Coach/Medical) a accès si rattaché au Club (userId)
       allow read, write: if isSignedIn() && getProfile().clubId == userId;

       // Les Parents peuvent lire les données de leurs propres enfants
       // Nécessite que le document contienne parentId
       allow read: if isSignedIn() && (
         resource.data.parentId == request.auth.uid || 
         getProfile().role == 'parent' && resource.data.parentId == request.auth.uid
       );
    }
  }
}