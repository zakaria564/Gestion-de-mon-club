rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SECOURS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- PROFILS UTILISATEURS ---
    match /userProfiles/{userId} {
      // Un utilisateur peut lire et créer son propre profil
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      
      // Un utilisateur peut mettre à jour son propre profil (sauf le rôle, idéalement, mais on reste simple ici)
      // L'admin peut mettre à jour n'importe quel profil (pour changer les rôles)
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Seul l'admin peut lister tous les profils (pour la page Équipe Staff)
      allow list: if isAdmin();
    }

    // --- DONNÉES PRIVÉES DU CLUB (Hiérarchie existante) ---
    // Cette règle couvre : players, coaches, calendarEvents, results, playerPayments, coachSalaries, opponents
    match /users/{userId}/{document=**} {
       allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}